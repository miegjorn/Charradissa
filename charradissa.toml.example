[org]
name = "acme"
homeserver = "https://matrix.acme.internal"

[backend]
type = "matrix"

[concierge]
archival_interval_hours = 24
convergence_interval_hours = 6
daily_token_budget = 50000

[approval]
timeout_minutes = 60

[tasks]
type = "jira"
base_url = "https://acme.atlassian.net"
project_key = "PROJ"

[projects]
autodiscover = true

# Per-room agent routing (optional).
# Org rooms (e.g. Guilhem) use the default GUILHEM_URL; no config needed.
[agents]
default = "http://guilhem.agents.svc.cluster.local:8080"

# Component-agent routes: map specific Matrix room IDs to component pod URLs.
# Each matched room POSTs to <url>/matrix/reply with the standard turn body.
[agents.routes]
"!gardian-room:occitane.guilhem" = "http://gardian.agents.svc.cluster.local:8080"
"!farga-room:occitane.guilhem"   = "http://farga.agents.svc.cluster.local:7500"

# Project-backed agents: each [[agents.project]] entry maps one or more Matrix
# rooms to an Amassada endpoint. Charradissa injects project_id into the turn
# body so Amassada can resolve the right persona from its project registry.
# {session_id} expands to a stable, URL-safe handle derived from the room, so the
# project's conversation reuses the same Amassada session across turns.
[[agents.project]]
type = "amassada_backed"
rooms = ["!room-projet-a:occitane.guilhem"]
project_id = "my-project"
endpoint = "http://amassada.agents.svc.cluster.local:7700/sessions/{session_id}/message"

# Component agents (in-process): wire a room to a Responder without a separate
# HTTP pod. Useful for lightweight helpers that don't need their own container.
[[component_agents]]
room_id = "!help-room:occitane.guilhem"
model   = "claude-opus-4-5"
system  = "You are a helpful assistant embedded in Matrix."
